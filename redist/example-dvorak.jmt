# jamotong 통합 자판 정의 (.jmt) — 정적 1:1 리맵 예제 (Type = static)
#
# QWERTY 물리 키가 내는 문자를 다른 문자로 바꾸는 단순 자판(드보락·콜맥 등)에 씁니다.
#   Map <키…> = <출력…>   키 나열 = 배열 지정 (좌우 같은 길이, 위치 대응)
#   Map <키> = <출력>      단건 지정 (길이 1의 특수형; 대문자/기호는 각각 따로)
# 키 나열엔 공백을 쓸 수 없으니 스페이스 키 등은 단건으로 지정하세요.
# 아래는 형식 예시(일부 키만) — 실제로는 드보락 전체를 채워 쓰거나, 내장 en_dvorak을 쓰세요.

Type = static
Name = ex_static
Abbrev = eSt

# 한 줄로 윗줄 전체 (배열 지정)
Map qwertyuiop = ',.pyfgcrl

# 단건 지정도 그대로 가능
Map [ = /
Map ] = =
